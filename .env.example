# Nombre del proyecto.
# Se utiliza en el index, PWA y etiquetas meta.
VITE_APP_NAME=

# Descripción del proyecto.
# Se utiliza en etiquetas meta.
VITE_APP_DESCRIPTION=

# URL pública completa del proyecto.
# Se utiliza en etiquetas meta.
VITE_APP_URL=

# URL del repositorio del proyecto.
# Se utiliza en la sección de créditos del diálogo de configuración.
VITE_APP_REPO=

# Disponibilidad de las funciones de Netlify (true/false).
# Habilita o deshabilita la detección de imágenes placeholder.
VITE_FUNCTIONS_ENABLED=

# Clave de verificación de Google Search Console.
# Se utiliza en la etiqueta meta google-site-verification.
VITE_GOOGLE_SITE_VERIFICATION=