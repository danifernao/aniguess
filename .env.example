# Nombre del proyecto.
# Se utiliza en el index, PWA, etiquetas meta y componentes de UI.
VITE_APP_NAME=

# Descripción del proyecto.
# Se utiliza en etiquetas meta.
VITE_APP_DESCRIPTION=

# URL pública completa del proyecto (incluye https://).
# Se utiliza en etiquetas meta.
VITE_APP_URL=

# Dominio del proyecto sin protocolo (sin https://).
# Se utiliza en la generación de imágenes para compartir estadísticas.
VITE_APP_HOST=

# URL del repositorio del proyecto.
# Se utiliza en la sección de créditos del diálogo de configuración.
VITE_APP_REPO=